// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Log {

  id            Int       @id @default(autoincrement())

  actor         String

  action        String

  payload       Json

  previousHash  String?

  hash          String

  merkleRoot    String?

  createdAt     DateTime  @default(now())

  @@index([actor])

  @@index([createdAt])

}
