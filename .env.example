####################################
# SERVER
####################################

PORT=5000
NODE_ENV=development

####################################
# DATABASE
####################################

DATABASE_URL="postgresql://postgres:postgres@db:5432/tamperlog?schema=public"

####################################
# SECURITY
####################################

API_KEY=potens-secret-api-key

####################################
# LOGGING
####################################

LOG_LEVEL=info

####################################
# EXPORT
####################################

EXPORT_LIMIT=5000

####################################
# MERKLE
####################################

MERKLE_BATCH_SIZE=100

####################################
# RATE LIMIT
####################################

RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100