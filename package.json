{
  "name": "potens-intern-backend-siddharth-jagtap",
  "version": "1.0.0",
  "description": "Tamper Evident Append Only Log Service",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",

    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "jest --watch",

    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",

    "verify": "node scripts/verify.js",

    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "tamper-evident",
    "append-only",
    "blockchain",
    "sha256",
    "merkle-tree",
    "audit-log"
  ],
  "author": "Siddharth Jagtap",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "commander": "^14.0.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.1",
    "prisma": "^6.10.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^9.30.1",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3"
  },
  "engines": {
    "node": ">=22"
  }
}